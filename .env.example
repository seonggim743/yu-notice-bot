# =====================================================
# Yu Notice Bot V2 - Environment Variables Template
# =====================================================
# Copy this file to .env and fill in your actual values
# =====================================================

# =====================================================
# TELEGRAM [REQUIRED]
# =====================================================
# Bot Token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Target Chat ID (group or channel ID)
CHAT_ID=your_chat_id_here

# Topic Map: Route notices to specific forum topics
# Format: {"site_key": "topic_id"}
TELEGRAM_TOPIC_MAP={"yu_news": "1", "cse_notice": "2", "dev": "99"}

# =====================================================
# DATABASE (Supabase) [REQUIRED]
# =====================================================
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# =====================================================
# AI (Google Gemini) [REQUIRED]
# =====================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================
# DISCORD [REQUIRED for Discord notifications]
# =====================================================
# Bot Token from Discord Developer Portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Channel Map: Route notices to specific channels
# Format: {"site_key": "channel_id"}
DISCORD_CHANNEL_MAP={"yu_news": "channel_id_1", "cse_notice": "channel_id_2", "dev": "channel_id_3"}

# Forum Tags: Map site_keys to Discord forum tags
# Format: {"site_key": {"tag_name": "tag_id"}}
DISCORD_TAG_MAP={"yu_news": {"긴급": "tag_id_1", "장학": "tag_id_2"}}

# =====================================================
# EOULLIM LOGIN (Optional - for protected pages)
# =====================================================
YU_EOULLIM_ID=your_student_id
YU_EOULLIM_PW=your_password

# =====================================================
# DEV NOTIFICATION (Optional)
# =====================================================
# Where to route operational/error messages: "telegram" or "discord"
DEV_PLATFORM=telegram
# Channel/topic ID for dev messages (used by DevNotifier)
DEV_CHANNEL_ID=

# =====================================================
# RUNTIME LIMITS (Optional - sensible defaults shown)
# =====================================================
# Hard cap on AI summaries per scrape run (cost / quota guard)
MAX_AI_SUMMARIES=50
# Seconds between AI API calls to smooth rate limits
AI_CALL_DELAY=7.0
# Seconds between processing individual notices
NOTICE_PROCESS_DELAY=0.5
# Max PDF preview images generated per scrape run
MAX_PREVIEWS=10

# =====================================================
# CANVAS LMS INTEGRATION (Optional)
# =====================================================
# Set CANVAS_ENABLED=true to enable. Bot then polls Canvas every
# CANVAS_POLL_INTERVAL seconds for new assignments / announcements / grades.
CANVAS_ENABLED=false
CANVAS_API_URL=https://canvas.yu.ac.kr
CANVAS_API_TOKEN=your_canvas_personal_access_token
CANVAS_POLL_INTERVAL=1800
